# Spotify app credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret

# Must match the redirect URI registered in your Spotify app settings
# LOCAL DEV:  http://127.0.0.1:8000/auth/callback  (Spotify allows http on 127.0.0.1)
# RAILWAY:    https://musara-backend.up.railway.app/auth/callback
REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key

# LOCAL DEV:  http://localhost:5173
# RAILWAY:    https://musara-frontend.up.railway.app
FRONTEND_URL=http://localhost:5173
